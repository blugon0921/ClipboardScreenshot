{
  "schemaVersion": 1,
  "id": "clipboard_screenshot",
  "version": "${version}",
  "name": "ClipboardScreenshot",
  "description": "Adds a 'Copy screenshot to clipboard' key",
  "authors": ["Blugon0921"],
  "contact": {
    "sources": "https://github.com/blugon0921/ClipboardScreenshot",
    "issues": "https://github.com/blugon0921/ClipboardScreenshot/issues"
  },
  "license": "MIT",
  "icon": "assets/clipboardscreenshot/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "kr.blugon.clipboardscreenshot.client.ClipboardScreenshotClientKt::initClient"
      }
    ],
    "modmenu": [
      "kr.blugon.clipboardscreenshot.client.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "clipboardscreenshot.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "fabric-api": "*",
    "minecraft": ">=26.1",
    "yet_another_config_lib_v3": ">=${yacl_version}",
    "modmenu": ">=${modmenu_version}"
  }
}
